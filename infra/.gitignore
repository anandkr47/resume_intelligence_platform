# SSL Certificates (never commit private keys)
ssl/dev/*.pem
ssl/dev/*.key
ssl/prod/*.pem
ssl/prod/*.key
*.pem
*.key
*.crt
*.csr

# Backup files
backup/*.dump
backup/*.rdb
backup/*.gz
backup/*.zip

# Ansible
ansible/.vault_pass
ansible/group_vars/*/vault.yml

# Environment files
.env
.env.local
*.env

# Logs
*.log
