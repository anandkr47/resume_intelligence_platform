{
  "name": "@resume-platform/upload-service",
  "version": "1.0.0",
  "description": "Upload service for resume files",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "fastify": "^4.24.3",
    "@fastify/cors": "^8.4.0",
    "@fastify/multipart": "^8.0.0",
    "uuid": "^9.0.1",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "@resume-platform/config": "*",
    "@resume-platform/logger": "*",
    "@resume-platform/queue-lib": "*"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.7",
    "@types/pg": "^8.10.9",
    "@types/node": "^20.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
